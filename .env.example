# ──────────────────────────────────────────────
# Ascend AI — Environment Configuration
# Copy to .env and fill in your values
# ──────────────────────────────────────────────

# Server
PORT=3000
NODE_ENV=production

# ── OpenAI ───────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-5.4-mini

# ── Brave Search ─────────────────────────────
BRAVE_SEARCH_API_KEY=BSA...

# ── Google (Service Account) ─────────────────
# Path to your Google Cloud service account JSON key file
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=./credentials/google-sa.json
# The ID of your "Clients" folder in Google Drive
# (Right-click folder → Get link → extract ID from URL)
GOOGLE_DRIVE_PARENT_FOLDER_ID=

# ── Slack ────────────────────────────────────
SLACK_BOT_TOKEN=xoxb-...
SLACK_SIGNING_SECRET=
SLACK_CHANNEL_ID=C...

# ── Gmail SMTP ───────────────────────────────
# Use a Gmail App Password (not your regular password)
# https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM="Ascend AI Marketing" <your@gmail.com>

# ── Audit Config ─────────────────────────────
MAX_AUDIT_ATTEMPTS=3
AUDIT_PASS_THRESHOLD=7

# ── Optional ─────────────────────────────────
# Webhook secret for verifying Tally requests
TALLY_WEBHOOK_SECRET=
